# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key-here

# JWT secret for verifying frontend auth tokens (Dashboard → Settings → API → JWT Secret)
# If not set, JWT verification is skipped (dev mode)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── AI / LLM ──────────────────────────────────────────────
BYTEZ_API_KEY=your-bytez-key-here
GEMINI_API_KEY=your-gemini-key-here

# Model names (defaults shown — override to use different versions)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# BYTEZ_MODEL=google/gemini-2.5-flash-lite

# ─── Redis (optional — falls back to in-memory) ────────────
# REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
# APP_VERSION=4.2.0

# ─── CORS (comma-separated origins) ────────────────────────
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Rate limits ────────────────────────────────────────────
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_UPLOAD=10/minute
# RATE_LIMIT_AI=20/minute
# RATE_LIMIT_HEAVY=30/minute

# ─── Upload ─────────────────────────────────────────────────
# MAX_UPLOAD_BYTES=5000000

# ─── Cache TTLs (seconds) ──────────────────────────────────
# FORECAST_CACHE_TTL=3600
# RAG_CACHE_TTL=86400
# DATASET_CACHE_TTL=300

# ─── Curriculum ─────────────────────────────────────────────
# MIN_QUIZ_UNLOCK_SCORE=70.0

# ─── Admin ──────────────────────────────────────────────────
# ADMIN_EMAILS=admin@campussync.ai,demo@campussync.ai

# ─── Encryption (optional — for resume-at-rest encryption) ─
# RESUME_ENCRYPTION_KEY=your-fernet-key-here
