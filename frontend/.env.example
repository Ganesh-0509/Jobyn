# CampusSync Edge Frontend Environment Variables
# Copy this file to .env and fill in the values

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000

# Supabase — get from: https://supabase.com/dashboard/project/<id>/settings/api
# Use the anon/public key here (NOT service_role)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin access is determined by the Supabase `app_metadata.role == 'admin'`
# claim (set via the service key / dashboard), NOT a frontend env var.
